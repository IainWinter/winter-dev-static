---
import '../styles/global.css';
import TopPanel from '../components/TopPanel.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
}

const { title = 'Winter' } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <link rel="icon" href="/favicon.ico" />
        <link rel="preload" href="/fonts/NanumMyeongjo400.woff2" as="font" type="font/woff2" crossorigin />
        <link rel="preload" href="/fonts/NanumMyeongjo700.woff2" as="font" type="font/woff2" crossorigin />
        <ClientRouter />
        <script is:inline>
            function applyTheme() {
                const theme = localStorage.getItem('theme') || 'dark';
                document.documentElement.classList.remove('dark', 'light');
                document.documentElement.classList.add(theme);
            }

            applyTheme();
            document.addEventListener('astro:after-swap', applyTheme);
        </script>
    </head>
    <body>
        <div class="page-container">
            <TopPanel />
            <slot />
        </div>

        <script is:inline>
            function setHasScrollbar() {
                const scrollbarWidth = Math.max(window.innerWidth - document.documentElement.clientWidth - 1, 0);
                document.body.style.paddingLeft = `${scrollbarWidth}px`;
            }

            setHasScrollbar();

            document.addEventListener('astro:after-swap', () => {
                setHasScrollbar();
            });
        </script>
    </body>
</html>
